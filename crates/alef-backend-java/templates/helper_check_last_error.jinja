    private static void checkLastError() throws Throwable {
        int errCode = (int) NativeLib.{{ prefix_upper }}_LAST_ERROR_CODE.invoke();
        if (errCode != 0) {
            var ctxPtr = (MemorySegment) NativeLib.{{ prefix_upper }}_LAST_ERROR_CONTEXT.invoke();
            String msg = ctxPtr.reinterpret(Long.MAX_VALUE).getString(0);
            switch (errCode) {
                case 1 -> throw new InvalidInputException(msg);
                case 2 -> throw dispatchCrawlError(msg);
                default -> throw new {{ class_name }}Exception(errCode, msg);
            }
        }
    }

    private static Throwable dispatchCrawlError(final String msg) {
        if (msg.contains("timeout:") || msg.contains("[network:timeout]")) {
            return new TimeoutException(msg);
        }
        if (msg.contains("connection:") || msg.contains("[network:connection]")) {
            return new ConnectionException(msg);
        }
        if (msg.contains("dns:") || msg.contains("[network:dns]")) {
            return new DnsException(msg);
        }
        if (msg.contains("ssl:") || msg.contains("[network:ssl]")) {
            return new SslException(msg);
        }
        if (msg.contains("[network:proxy]")) {
            return new OtherException(msg);
        }
        if (msg.contains("invalid_config:")) {
            return new InvalidConfigException(msg);
        }
        if (msg.contains("unauthorized:")) {
            return new UnauthorizedException(msg);
        }
        if (msg.contains("forbidden:")) {
            if (msg.contains("waf")) {
                return new WafBlockedException(msg);
            }
            return new ForbiddenException(msg);
        }
        if (msg.contains("not_found:")) {
            return new NotFoundException(msg);
        }
        if (msg.contains("gone:")) {
            return new GoneException(msg);
        }
        if (msg.contains("server_error:")) {
            return new ServerErrorException(msg);
        }
        if (msg.contains("bad_gateway:")) {
            return new BadGatewayException(msg);
        }
        if (msg.contains("rate_limited:")) {
            return new RateLimitedException(msg);
        }
        if (msg.contains("data_loss:")) {
            return new DataLossException(msg);
        }
        if (msg.contains("browser:")) {
            return new BrowserErrorException(msg);
        }
        if (msg.contains("browser_timeout:")) {
            return new BrowserTimeoutException(msg);
        }
        return new CrawlErrorException(msg);
    }
