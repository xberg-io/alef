    private static byte[] MarshalBytesFromIntPtr(IntPtr ptr) {
        if (ptr == IntPtr.Zero) return Array.Empty<byte>();
        var json = Marshal.PtrToStringUTF8(ptr) ?? "[]";
        return JsonSerializer.Deserialize<byte[]>(json) ?? Array.Empty<byte>();
