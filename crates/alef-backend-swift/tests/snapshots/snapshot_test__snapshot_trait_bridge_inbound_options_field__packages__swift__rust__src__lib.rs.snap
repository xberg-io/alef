    pub fn new(inner: ffi::SwiftHtmlVisitorBox) -> Self {
        Self { inner }
    }
}
impl demo::visitor::HtmlVisitor for SwiftHtmlVisitorWrapper {
    fn visit_node(&self, tag: str) -> () {
        self.inner.alef_visit_node(tag);
    }

}


