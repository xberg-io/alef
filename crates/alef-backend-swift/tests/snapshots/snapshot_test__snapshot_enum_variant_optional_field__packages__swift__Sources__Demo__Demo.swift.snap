// Generated by alef. Do not edit by hand.
// swift-format-ignore-file

import Foundation
import RustBridge

/// A text chunk.
public struct Chunk: Codable, Sendable, Hashable {
    public let text: String
    public init(text: String) {
        self.text = text
    }
}

// MARK: - Internal FFI conversions for Chunk
internal extension Chunk {
    init(_ rb: RustBridge.Chunk) throws {
        self.text = rb.text().toString()
    }
    func intoRust() throws -> RustBridge.Chunk {
        return RustBridge.Chunk(self.text)
    }
}

/// Streaming event enum.
public enum StreamEvent {
    /// A data event carrying an optional chunk.
    case data(chunk: Chunk?)
    /// An error event with an optional message.
    case error(message: String?)
    /// Stream completed with item count.
    case done(count: UInt32)
}
