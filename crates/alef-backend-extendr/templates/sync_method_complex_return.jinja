let maybe_fn = self.inner.dollar("{{ method_name }}");
let fn_robj = match maybe_fn {
    Ok(v) if !v.is_null() && !v.is_na() => v,
{% if has_error %}
    _ => return Err({{ core_import }}::KreuzbergError::Plugin {
        message: format!("Plugin '{}' missing method '{{ method_name }}'", self.cached_name),
        plugin_name: self.cached_name.clone(),
    }),
{% else %}
    _ => return Default::default(),
{% endif %}
};

{% if empty_args %}
let result = fn_robj.call(extendr_api::Pairlist::new());
{% else %}
let args = extendr_api::Pairlist::from_pairs(&[{{ args_pairs }}]);
let result = fn_robj.call(args);
{% endif %}

// R callbacks return JSON-encoded strings (e.g. via `jsonlite::toJSON`). Parse the string
// payload back into the trait return type. Note: `extendr_api::Robj` does not implement
// `serde::Serialize`, so we cannot serialize it directly — the caller must serialize on
// the R side.
match result {
    Err(_) => {
{% if has_error %}
        Err({{ core_import }}::KreuzbergError::Plugin {
            message: format!("Plugin '{}' method '{{ method_name }}' failed", self.cached_name),
            plugin_name: self.cached_name.clone(),
        })
{% else %}
        Default::default()
{% endif %}
    }
    Ok(val) => {
        let payload = val.as_str().unwrap_or("");
        match serde_json::from_str::<{{ return_type }}>(payload) {
{% if has_error %}
            Ok(parsed) => Ok(parsed),
            Err(_) => Err({{ core_import }}::KreuzbergError::Plugin {
                message: format!("Plugin '{}' method '{{ method_name }}' deserialization failed", self.cached_name),
                plugin_name: self.cached_name.clone(),
            }),
{% else %}
            Ok(parsed) => parsed,
            Err(_) => Default::default(),
{% endif %}
        }
    }
}
