// Generated by alef. Do not edit by hand.

const std = @import("std");
pub const c = @cImport(@cInclude("demo.h"));

/// Free a string allocated by the FFI layer.
/// The pointer must have been returned by a `demo_*` C function.
/// Do NOT call this twice on the same pointer.
pub fn _free_string(ptr: [*c]u8) void {
    c.demo_free_string(ptr);
}

/// Retrieve the last error set by the FFI layer, if any.
/// Returns a slice into thread-local storage valid until the next FFI call.
pub fn _last_error() ?[]const u8 {
    const _code = c.demo_last_error_code();
    if (_code == 0) return null;
    const _ctx = c.demo_last_error_context();
    if (_ctx == null) return null;
    return std.mem.sliceTo(_ctx, 0);
}

/// Map the last FFI error to a typed error from the given error set.
/// Coarse fallback: returns the first declared variant. Per-code dispatch
/// will replace this once the IR exposes per-variant numeric codes.
inline fn _first_error(comptime E: type) E {
    const fields = @typeInfo(E).ErrorSet orelse return @as(E, error.Unknown);
    if (fields.len == 0) unreachable;
    return @field(E, fields[0].name);
}

/// Errors emitted by demo operations.
pub const DemoError = error {
    InvalidInput,
    ProcessingFailed,
};

/// A demo configuration struct.
pub const Config = struct {
    value: i32,
    label: [:0]const u8,
    tag: ??[:0]const u8,
};

/// Processing status.
pub const Status = enum {
    active,
    inactive,
};

/// Process input and return a result.
pub fn process(input: []const u8, count: u32) (DemoError||error{OutOfMemory})![]u8 {
    const input_z: [*:0]u8 = try std.fmt.allocPrintZ(
        std.heap.c_allocator, "{s}", .{input},
    );
    const _result = c.demo_process(input_z, count);
    if (c.demo_last_error_code() != 0) {
        return _first_error(DemoError);
    }
    std.heap.c_allocator.free(input_z[0..std.mem.len(input_z)]);
    return blk: {
        const slice = std.mem.sliceTo(_result, 0);
        const owned = try std.heap.c_allocator.dupe(u8, slice);
        _free_string(_result);
        break :blk owned;
    };
}
