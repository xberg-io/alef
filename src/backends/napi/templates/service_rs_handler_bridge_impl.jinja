                    Either::A(promise) => promise.await.map_err(|e| Box::new(e) as {{ box_err }})?.0,
                    Either::B(value) => value.0,
                };
                serde_json::from_value(resp_json)
                    .map_err(|e| Box::new(e) as {{ box_err }})
            }
            .await;

            {{ tail }}
        })
    }
}
