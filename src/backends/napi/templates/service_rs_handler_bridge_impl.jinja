        Box::pin(async move {
            // Serialize request to JSON and call the ThreadsafeFunction
            let outcome: {{ wire_output }} = async move {
                let req_json = serde_json::to_value(&{{ wire_name }})
                    .map_err(|e| Box::new(e) as {{ box_err }})?;
