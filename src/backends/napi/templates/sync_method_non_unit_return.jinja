let __env = self.env();
let __obj = match self.obj(&__env) {
    Ok(o) => o,
{% if has_default_impl %}
    // Object disposed/unavailable — treat like a missing method (no-op default).
    Err(_) => return {% if has_error %}Ok(Default::default()){% else %}Default::default(){% endif %},
{% elif has_error %}
    Err(e) => return Err({{ error_lookup }}),
{% else %}
    Err(_) => return Default::default(),
{% endif %}
};
let func: napi::bindgen_prelude::Function<{{ args_tuple_ty }}, napi::bindgen_prelude::Unknown> = match __obj.get_named_property("{{ method_name }}")
    .or_else(|_| __obj.get_named_property("{{ snake_case_method_name }}")) {
    Ok(f) => f,
{% if has_default_impl %}
    // Method has a default impl on the Rust trait — treat missing JS property as a no-op
    // (the foreign object opted out of overriding it). Falls back to Default::default().
    Err(_) => return {% if has_error %}Ok(Default::default()){% else %}Default::default(){% endif %},
{% elif has_error %}
    Err(e) => return Err({{ error_lookup }}),
{% else %}
    Err(_) => return Default::default(),
{% endif %}
};

{% if empty_args %}
let result = func.call(());
{% else %}
let result = func.call(napi::bindgen_prelude::FnArgs::from({{ tuple_args }}));
{% endif %}

{% if has_error %}
match result {
    Err(e) => Err({{ error_call }}),
    Ok(val) => {
        // Convert JS value to Rust type via string coercion
        let s = val.coerce_to_string()
            .and_then(|s| s.into_utf8())
            .and_then(|s| s.into_owned())
            .map_err(|e| {{ error_coercion }})?;
        match s.as_str() {
            // null/empty is a protocol error for Result-returning methods: the JS
            // implementation must always return a serialisable value, never null.
            // Avoid requiring Default on return types that are intentionally
            // excluded from bindings.
            "" | "null" => Err({{ error_parse }}),
            _ => {
                serde_json::from_str::<_>(&s).map_err(|_| {{ error_parse }})
            }
        }
    }
}
{% else %}
match result {
    // This method's Rust signature is infallible, so a JS exception cannot
    // propagate. Log before substituting the default — a silent default is
    // indistinguishable from a real result to the caller.
    Err(e) => {
        eprintln!("[{{ wrapper }}] host '{{ method_name }}' threw; returning default: {e}");
        Default::default()
    }
    Ok(val) => {
        // Convert JS value to Rust type via string coercion
        let s = match val.coerce_to_string()
            .and_then(|s| s.into_utf8())
            .and_then(|s| s.into_owned()) {
            Ok(s) => s,
            Err(e) => {
                eprintln!("[{{ wrapper }}] host '{{ method_name }}' returned a value that could not be coerced to a string; returning default: {e}");
                return Default::default();
            }
        };
        match s.as_str() {
            // null/undefined is a legitimate "no value" answer for infallible
            // returns (mirrors the extendr backend) — no log.
            "" | "null" => Default::default(),
            _ => match serde_json::from_str::<_>(&s) {
                Ok(v) => v,
                Err(e) => {
                    eprintln!("[{{ wrapper }}] host '{{ method_name }}' returned an unparseable value; returning default: {e}");
                    Default::default()
                }
            }
        }
    }
}
{% endif %}
