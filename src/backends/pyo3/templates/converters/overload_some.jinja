@overload
{% if has_visitor_override %}
def _to_rust_{{ snake }}(
    value: {{ type_name }} | dict[str, Any] | str,
    _visitor_override: {{ bridge_visitor_type }} | None = None,
) -> _rust.{{ type_name }}: ...
{% else %}
def _to_rust_{{ snake }}(value: {{ type_name }} | dict[str, Any] | str) -> _rust.{{ type_name }}: ...
{% endif %}
