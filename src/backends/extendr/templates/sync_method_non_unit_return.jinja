let maybe_fn = self.inner.dollar("{{ method_name }}");
let fn_robj = match maybe_fn {
    Ok(v) if !v.is_null() && !v.is_na() => v,
{% if has_error %}
    _ => return Err({{ missing_method_error }}),
{% else %}
    _ => return Default::default(),
{% endif %}
};

{% if empty_args %}
let result = fn_robj.call(extendr_api::Pairlist::new());
{% else %}
let args = extendr_api::Pairlist::from_pairs(&[{{ args_pairs }}]);
let result = fn_robj.call(args);
{% endif %}

{% if has_error %}
match result {
    Err(_) => Err({{ failed_method_error }}),
    Ok(val) => {
        let s = val.as_string().ok().and_then(|mut v| {
            if v.is_empty() { None } else { Some(v.remove(0)) }
        }).unwrap_or_default();

        match s.as_str() {
            "" | "null" => Ok(Default::default()),
            _ => serde_json::from_str::<_>(&s).map_err(|e| {{ parse_error }})
        }
    }
}
{% else %}
match result {
    // This method's Rust signature is infallible, so an R error cannot
    // propagate. Log before substituting the default — a silent default is
    // indistinguishable from a real result to the caller.
    Err(e) => {
        eprintln!("[{{ wrapper }}] host '{{ method_name }}' raised; returning default: {e}");
        Default::default()
    }
    Ok(val) => {
        let s = val.as_string().ok().and_then(|mut v| {
            if v.is_empty() { None } else { Some(v.remove(0)) }
        }).unwrap_or_default();

        match s.as_str() {
            "" | "null" => Default::default(),
            _ => serde_json::from_str::<_>(&s).unwrap_or_else(|e| {
                eprintln!("[{{ wrapper }}] host '{{ method_name }}' returned an unparseable value; returning default: {e}");
                Default::default()
            })
        }
    }
}
{% endif %}
