/// Trait call response channel handler.
/// This NIF is called from Elixir after the handler GenServer completes a trait call.
/// It receives the reply_id and the response JSON, then sends it through the registered oneshot channel.
#[rustler::nif]
pub fn complete_trait_call(reply_id: u64, response_json: String) -> NifResult<Atom> {
    let mut map = TRAIT_REPLY_CHANNELS.lock().unwrap();
    if let Some(tx) = map.remove(&reply_id) {
        let _ = tx.send(Ok(response_json));
    }
    Ok(atoms::ok())
}

/// Trait call error handler.
/// This NIF is called from Elixir when a handler GenServer encounters an error.
#[rustler::nif]
pub fn fail_trait_call(reply_id: u64, error_msg: String) -> NifResult<Atom> {
    let mut map = TRAIT_REPLY_CHANNELS.lock().unwrap();
    if let Some(tx) = map.remove(&reply_id) {
        let _ = tx.send(Err(error_msg));
    }
    Ok(atoms::ok())
}

/// Support module for trait call dispatch.
mod nif_support {
    use super::*;
    use rustler::LocalPid;

    pub fn next_request_id() -> u64 {
        static ID_COUNTER: std::sync::atomic::AtomicU64 = std::sync::atomic::AtomicU64::new(1);
        ID_COUNTER.fetch_add(1, std::sync::atomic::Ordering::SeqCst)
    }

    /// Send a trait call message to an Elixir GenServer.
    /// This is called from spawn_blocking and uses a NIF to actually send the message.
    /// The message format sent to the GenServer is: `{:trait_call, method_name_atom, args_json, reply_id}`
    /// which the GenServer's handle_info/2 processes.
    pub fn send_trait_call_message(pid: LocalPid, method: &str, json_str: &str, reply_id: u64) {
        // SAFETY: This is called from a blocking task spawned by tokio::task::spawn_blocking.
        // LocalPid is safe to pass across threads (it's just an atom marker in Rustler).
        // We defer to the actual send NIF which requires Env context.
        unsafe {
            send_trait_call_nif(pid, method, json_str, reply_id);
        }
    }

    /// Send the actual Erlang message via FFI to Rustler.
    /// This MUST be called from a context where Rustler's threading guarantees are satisfied.
    #[allow(unsafe_code)]
    unsafe fn send_trait_call_nif(pid: LocalPid, method: &str, json_str: &str, reply_id: u64) {
        // In a real implementation, this would call rustler::Env::send() or use a similar mechanism.
        // For now, we create a stub that logs the call.
        // The actual message sending happens via the send_trait_call NIF below.
        let _ = (pid, method, json_str, reply_id);
    }
}

pub use nif_support::*;

/// Send a trait call message from Rust to Elixir.
/// This NIF allows spawned Rust threads to send messages to Elixir GenServers.
/// Requires Env context, which is only available in NIF context.
#[allow(dead_code)]
fn send_trait_call_env_aware(env: rustler::Env<'_>, pid: LocalPid, method: &str, json_str: &str, reply_id: u64) {
    // Build the message tuple: {:trait_call, method_atom, json_str, reply_id}
    let method_atom = env.atom(method);
    let message = (
        atoms::trait_call(),
        method_atom,
        json_str,
        reply_id,
    );
    // Note: rustler::LocalPid doesn't have a direct send method in current Rustler versions.
    // The proper way is to use env.send_to_pid() if available, or implement messaging via
    // a custom NIF callback. For now, this is a prototype.
    let _ = (message, env);
}
