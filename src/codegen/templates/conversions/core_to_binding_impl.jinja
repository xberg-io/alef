#[allow(clippy::redundant_closure, clippy::useless_conversion)]
impl From<{{ core_path }}{% if has_lifetime_params %}<'_>{% endif %}> for {{ binding_name }} {
    fn from(val: {{ core_path }}{% if has_lifetime_params %}<'_>{% endif %}) -> Self {
        {%- if is_newtype %}
        Self { _0: {{ newtype_inner_expr }} }
        {%- else %}
        Self {
            {%- for field in fields %}
            {{ field }},
            {%- endfor %}
        }
        {%- endif %}
    }
}
