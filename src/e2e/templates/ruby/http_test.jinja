{#- Ruby HTTP test method template

   Context variables:
   - fn_name: sanitized function name
   - description: fixture description as a Ruby string literal (already quoted)
   - skip_reason: optional skip reason (if test is skipped)
#}
{%- if skip_reason %}
  describe '{{ fn_name }}' do
    it {{ description }} do
      skip '{{ skip_reason }}'
    end
  end
{%- else %}
  describe '{{ fn_name }}' do
    it {{ description }} do
{% endif %}
