{#- TypeScript cache isolation setup template

   Context variables: none (uses fixed template)
#}
  let _alefTestCacheDir: string;

  beforeAll(() => {
    _alefTestCacheDir = mkdtempSync(join(tmpdir(), 'alef-e2e-'));
    configure({ cacheDir: _alefTestCacheDir });
  });

  afterAll(() => {
    configure({});
    try { rmSync(_alefTestCacheDir, { recursive: true, force: true }); } catch (_e) {}
  });
