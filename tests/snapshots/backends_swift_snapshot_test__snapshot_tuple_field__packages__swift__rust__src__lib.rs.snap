pub fn extract_keywords(text: String, config: KeywordConfig) -> Result<Vec<String>, String> {
    demo::extract_keywords(text, config.0).map_err(|e| e.to_string()).map(|v| v.into_iter().map(|s| s.to_string()).collect::<Vec<_>>())
}

pub fn keyword_config_from_json(json: String) -> Result<KeywordConfig, String> {
