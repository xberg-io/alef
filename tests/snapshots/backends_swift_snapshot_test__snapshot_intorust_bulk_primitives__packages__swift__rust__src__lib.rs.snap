pub struct Span(pub demo::Span);
impl Span {
    pub fn new(start_byte: usize, end_byte: usize) -> Span {
        Span(demo::Span {
            start_byte,
            end_byte,
        })
    }
    pub fn start_byte(&self) -> usize {
        ::serde_json::to_value(&self.0.start_byte).ok().and_then(|j| ::serde_json::from_value(j).ok()).unwrap_or_default()
    }
    pub fn end_byte(&self) -> usize {
        ::serde_json::to_value(&self.0.end_byte).ok().and_then(|j| ::serde_json::from_value(j).ok()).unwrap_or_default()
    }
}

pub fn span_from_json(json: String) -> Result<Span, String> {
    serde_json::from_str::<demo::Span>(&json)
        .map(Span)
        .map_err(|e| e.to_string())
}
