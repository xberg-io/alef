/// Register a Swift class implementation as a `ImageProcessor` plugin.
///
/// Wraps the Swift handle in `Arc<SwiftXxxWrapper>` and inserts it into the host registry.
/// Errors from the registry are stringified for swift-bridge transport.
pub fn register_image_processor(swift_box: ffi::SwiftImageProcessorBox) -> Result<(), String> {
    let arc: ::std::sync::Arc<dyn demo::plugins::ImageProcessor> = ::std::sync::Arc::new(SwiftImageProcessorWrapper::new(swift_box));
    let registry = demo::plugins::registry::get_image_processor_registry();
    let mut guard = registry.write();
    guard.register(arc).map_err(|e| e.to_string())
}
/// Unregister a previously-registered `ImageProcessor` plugin by name.
pub fn unregister_image_processor(name: String) -> Result<(), String> {
    let registry = demo::plugins::registry::get_image_processor_registry();
    let mut guard = registry.write();
    guard.remove(&name).map_err(|e| e.to_string())
}


