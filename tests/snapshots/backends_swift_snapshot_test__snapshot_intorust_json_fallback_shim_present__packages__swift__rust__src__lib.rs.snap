pub struct Metadata(pub demo::Metadata);
impl Metadata {
    pub fn kind(&self) -> String {
        self.0.kind.clone()
    }
    pub fn attrs(&self) -> String {
        serde_json::to_string(&self.0.attrs).expect("serializable attrs")
    }
}

pub fn metadata_from_json(json: String) -> Result<Metadata, String> {
    serde_json::from_str::<demo::Metadata>(&json)
        .map(Metadata)
        .map_err(|e| e.to_string())
}
