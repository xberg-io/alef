pub struct Data(pub demo::Data);
impl Data {
    pub fn new(value: i32) -> Data {
        Data(demo::Data {
            value,
        })
    }
    pub fn value(&self) -> i32 {
        self.0.value.clone()
    }
}

pub enum Result {
    Success,
    Error,
}

impl From<demo::Result> for Result {
    fn from(val: demo::Result) -> Self {
        match val {
            demo::Result::Success { .. } => Self::Success,
            demo::Result::Error { .. } => Self::Error,
        }
    }
}

impl Result {
    pub fn to_string(&self) -> String {
        match self {
            Self::Success => "Success".to_string(),
            Self::Error => "Error".to_string(),
        }
    }
}
