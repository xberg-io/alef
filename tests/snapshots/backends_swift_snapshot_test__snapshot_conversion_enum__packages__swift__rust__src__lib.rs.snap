        fn to_string(&self) -> String;
    }

}

pub struct Data(pub demo::Data);
impl Data {
    pub fn new(value: i32) -> Data {
        Data(demo::Data {
            value,
        })
    }
    pub fn value(&self) -> i32 {
        self.0.value.clone()
    }
}

pub enum Result {
    /// Data variants not directly bridgeable — represented as Unknown.
    Unknown,
}

impl From<demo::Result> for Result {
