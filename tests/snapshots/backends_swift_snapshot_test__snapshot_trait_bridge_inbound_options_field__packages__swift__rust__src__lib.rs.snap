    fn from(v: demo::visitor::CallbackHandle) -> Self { Self(v) }
}
impl From<CallbackHandle> for demo::visitor::CallbackHandle {
    fn from(v: CallbackHandle) -> Self { v.0 }
}
impl From<demo::options::RenderOptions> for RenderOptions {
    fn from(v: demo::options::RenderOptions) -> Self { Self(v) }
}

/// Construct a `CallbackHandle` from a Swift `SwiftMarkupVisitorBox` handle.
/// Called by Swift e2e tests via `makeMarkupVisitorCallbackHandle(...)` to build a
/// `CallbackHandle` that can be passed to the options-with-visitor helper.
pub fn make_markup_visitor_callback_handle(swift_box: ffi::SwiftMarkupVisitorBox) -> CallbackHandle {
    let __wrapper = SwiftMarkupVisitorWrapper::new(swift_box);
    let __inner: demo::visitor::CallbackHandle = ::std::sync::Arc::new(::std::sync::Mutex::new(__wrapper));
    CallbackHandle::from(__inner)
}

/// Deserialise a `RenderOptions` from JSON and attach a visitor handle to its
/// `visitor` field. Used by Swift e2e tests to thread a `CallbackHandle` into the
/// conversion call without needing a mutable post-construction setter.
pub fn render_options_from_json_with_visitor(json: String, visitor: Option<CallbackHandle>) -> Result<RenderOptions, String> {
    let mut __core: demo::options::RenderOptions = ::serde_json::from_str(&json).map_err(|e| e.to_string())?;
    __core.visitor = visitor.map(|h| <demo::visitor::CallbackHandle>::from(h));
    Ok(RenderOptions::from(__core))
}

pub fn render_options_from_json(json: String) -> Result<RenderOptions, String> {
    serde_json::from_str::<demo::options::RenderOptions>(&json)
        .map(RenderOptions)
        .map_err(|e| e.to_string())
}
