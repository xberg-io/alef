pub fn alef_phantom_vec_markup_visitor() -> Vec<MarkupVisitorBox> { Vec::new() }
pub fn markup_visitor_call_visit_node(this: &MarkupVisitorBox, tag: String) -> FlowDecision {
    FlowDecision::from(this.0.visit_node(tag))
}

/// Convert a stringified Swift error into the configured source-crate error type.
#[allow(dead_code)]
fn plugin_error_from_string(message: String) -> demo::Error {
    demo::Error::from(message)
}

/// JSON envelope returned by every fallible Swift trait method. Carries `Ok(T)`
/// as `{"ok": <serialised T>}` and `Err(String)` as `{"err": "<message>"}`.
/// Avoids swift-bridge 0.1.59's broken `Result<RustString, RustString>` codegen.
#[allow(dead_code)]
#[derive(::serde::Deserialize)]
#[serde(rename_all = "snake_case")]
enum InboundEnvelope<T> { Ok(T), Err(String) }

/// Deserialise a JSON envelope returned from a Swift FFI shim into a typed Result.
#[allow(dead_code)]
fn decode_inbound_envelope<T>(json: &str) -> std::result::Result<T, demo::Error>
where
    T: ::serde::de::DeserializeOwned,
{
    match ::serde_json::from_str::<InboundEnvelope<T>>(json) {
        Ok(InboundEnvelope::Ok(value)) => Ok(value),
        Ok(InboundEnvelope::Err(message)) => Err(plugin_error_from_string(message)),
        Err(e) => Err(plugin_error_from_string(format!("swift returned malformed envelope: {e}"))),
    }
}
/// Rust-side wrapper around a Swift class implementing the `MarkupVisitor` protocol.
///
/// The Swift instance is held via a `swift-bridge` opaque handle that retains
/// the underlying ARC reference for the lifetime of this struct. Send + Sync are
/// asserted unsafely: Swift classes used as trait bridges must be thread-safe.
pub struct SwiftMarkupVisitorWrapper {
    inner: ffi::SwiftMarkupVisitorBox,
}
unsafe impl Send for SwiftMarkupVisitorWrapper {}
unsafe impl Sync for SwiftMarkupVisitorWrapper {}

impl SwiftMarkupVisitorWrapper {
    /// Construct a new wrapper from a Swift `SwiftMarkupVisitorBox` handle.
    pub fn new(inner: ffi::SwiftMarkupVisitorBox) -> Self {
        Self { inner }
    }
}
impl demo::visitor::MarkupVisitor for SwiftMarkupVisitorWrapper {
    fn visit_node(&self, tag: String) -> demo::visitor::FlowDecision {
        let json = self.inner.alef_visit_node(tag);
        ::serde_json::from_str::<demo::visitor::FlowDecision>(&json).expect("swift markup_visitor.visit_node returned invalid JSON")
    }

}


