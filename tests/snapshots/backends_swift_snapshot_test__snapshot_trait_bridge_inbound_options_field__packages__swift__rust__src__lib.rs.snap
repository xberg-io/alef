    }
}

pub enum FlowDecision {
    Accept,
    Stop,
}

impl From<demo::visitor::FlowDecision> for FlowDecision {
    fn from(val: demo::visitor::FlowDecision) -> Self {
        match val {
            demo::visitor::FlowDecision::Accept => Self::Accept,
            demo::visitor::FlowDecision::Stop => Self::Stop,
        }
    }
}

impl FlowDecision {
    pub fn to_string(&self) -> String {
        match self {
            Self::Accept => "Accept".to_string(),
            Self::Stop => "Stop".to_string(),
        }
    }
}

