pub struct Point(pub demo::Point);
impl Point {
    pub fn new(row: u32, column: u32) -> Point {
        Point(demo::Point {
            row,
            column,
        })
    }
    pub fn row(&self) -> u32 {
        ::serde_json::to_value(&self.0.row).ok().and_then(|j| ::serde_json::from_value(j).ok()).unwrap_or_default()
    }
    pub fn column(&self) -> u32 {
        ::serde_json::to_value(&self.0.column).ok().and_then(|j| ::serde_json::from_value(j).ok()).unwrap_or_default()
    }
}

pub fn point_from_json(json: String) -> Result<Point, String> {
    serde_json::from_str::<demo::Point>(&json)
        .map(Point)
        .map_err(|e| e.to_string())
}
