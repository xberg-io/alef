pub struct Chunk(pub demo::Chunk);
impl Chunk {
    pub fn new(text: String) -> Chunk {
        let mut __target: demo::Chunk = ::std::default::Default::default();
        {
            // Try JSON parse first (handles enum/object values); on parse failure
            // treat the raw input as a JSON string scalar so plain `String` /
            // string-like enum fields don't end up empty for inputs that aren't
            // valid JSON tokens (e.g. `tts-1`).
            let __v = ::serde_json::from_str::<::serde_json::Value>(&text)
                .unwrap_or(::serde_json::Value::String(text.clone()));
            if let Ok(t) = ::serde_json::from_value(__v) { __target.text = t; }
        }
        Chunk(__target)
    }
    pub fn text(&self) -> String {
        self.0.text.clone()
    }
}

pub enum StreamEvent {
    Data,
    Error,
    Done,
}

impl From<demo::StreamEvent> for StreamEvent {
    fn from(val: demo::StreamEvent) -> Self {
        match val {
            demo::StreamEvent::Data { .. } => Self::Data,
            demo::StreamEvent::Error { .. } => Self::Error,
            demo::StreamEvent::Done { .. } => Self::Done,
        }
    }
}

impl StreamEvent {
    pub fn to_string(&self) -> String {
        match self {
            Self::Data => "Data".to_string(),
            Self::Error => "Error".to_string(),
            Self::Done => "Done".to_string(),
        }
    }
}

pub fn chunk_from_json(json: String) -> Result<Chunk, String> {
    serde_json::from_str::<demo::Chunk>(&json)
        .map(Chunk)
        .map_err(|e| e.to_string())
}
pub fn stream_event_from_json(json: String) -> Result<StreamEvent, String> {
    serde_json::from_str::<demo::StreamEvent>(&json)
        .map(StreamEvent::from)
        .map_err(|e| e.to_string())
}
