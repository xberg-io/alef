#[doc(hidden)]
pub fn __alef_phantom_vec_config() -> Vec<Config> { Vec::new() }
#[doc(hidden)]
pub fn __alef_phantom_vec_status() -> Vec<Status> { Vec::new() }

pub struct Config(pub demo::Config);
impl Config {
    pub fn value(&self) -> i32 {
        self.0.value.clone()
    }
    pub fn label(&self) -> String {
        format!("{:?}", &self.0.label)
    }
    pub fn tag(&self) -> String {
        serde_json::to_string(&self.0.tag).expect("serializable tag")
    }
}

pub enum Status {
    Active,
    Inactive,
}

impl From<demo::Status> for Status {
    fn from(val: demo::Status) -> Self {
        match val {
            demo::Status::Active => Self::Active,
            demo::Status::Inactive => Self::Inactive,
        }
    }
}

impl Status {
    pub fn to_string(&self) -> String {
        match self {
            Self::Active => "Active".to_string(),
            Self::Inactive => "Inactive".to_string(),
        }
    }
}

pub fn process(input: String, count: u32) -> Result<String, String> {
    demo::process(input, count).map_err(|e| e.to_string()).map(|s| s.to_string())
}
