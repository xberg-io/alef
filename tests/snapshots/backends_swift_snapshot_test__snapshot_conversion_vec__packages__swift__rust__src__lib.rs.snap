        type Item;
        #[swift_bridge(init)]
        fn new(id: u32) -> Item;
        fn id(&self) -> u32;
    }

    extern "Rust" {
        #[swift_bridge(swift_name = "getItems")]
        fn get_items() -> Vec<Item>;
    }

}

pub struct Item(pub demo::Item);
impl Item {
    pub fn new(id: u32) -> Item {
        Item(demo::Item {
            id,
        })
    }
    pub fn id(&self) -> u32 {
        self.0.id.clone()
    }
}

pub fn get_items() -> Vec<Item> {
    (demo::getItems()).into_iter().map(Item).collect::<Vec<_>>()
}
