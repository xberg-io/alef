// MARK: - Internal FFI conversions for RenderOptions
internal extension RenderOptions {
    init(_ rb: RustBridge.RenderOptionsRef) throws {
        self.timeoutMs = rb.timeoutMs()
    }

    func intoRust() throws -> RustBridge.RenderOptions {
        return RustBridge.RenderOptions(self.timeoutMs)
