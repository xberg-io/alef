public typealias CallbackHandle = RustBridge.CallbackHandle

/// Options for conversion.
public struct RenderOptions: Codable, Sendable, Hashable {
    public let timeoutMs: UInt32
    public init(timeoutMs: UInt32) {
        self.timeoutMs = timeoutMs
    }
